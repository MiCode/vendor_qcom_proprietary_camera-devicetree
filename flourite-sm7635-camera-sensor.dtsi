		};

		config {
			pins = "gpio92";
			bias-disable; /* No PULL */
			drive-strength = <2>; /* 2 MA */
		};
	};

	flourite_cci_i2c_scl2_active: flourite_cci_i2c_scl2_active {
		mux {
			/* CLK, DATA */
			pins = "gpio93";
