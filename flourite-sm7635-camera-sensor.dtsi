#include <dt-bindings/msm-camera.h>
&gcc {
	qcom,critical-devices = <&qupv3_se7_i2c>;
};

//wide
&cam_csiphy2 {
	compatible = "qcom,csiphy-v2.2.1-p16u", "qcom,csiphy";
};


//hap
&qupv3_se7_i2c {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "ok";

	wl28661d@28 {
		compatible = "xiaomi,wl28661d-pmic";
		reg = <0x28>;
		vin1-supply = <&S2B>;
		vin2-supply = <&BOB>;

		wl28661d_dvdd1: wl28661d-regulator@0 {
			cell-index = <0>;
			reg = /bits/ 8 <0x3>;
			type = "dvdd";
			regulator-name = "wl28661d_dvdd1";
			regulator-min-microvolt = <504000>;
			regulator-max-microvolt = <1384000>;
		};

		wl28661d_dvdd2: wl28661d-regulator@1 {
			cell-index = <1>;
			reg = /bits/ 8 <0x4>;
			type = "dvdd";
			regulator-name = "wl28661d_dvdd2";
			regulator-min-microvolt = <504000>;
			regulator-max-microvolt = <1384000>;
		};

		wl28661d_avdd1: wl28661d-regulator@2 {
			cell-index = <2>;
			reg = /bits/ 8 <0x5>;
			type = "avdd";
			regulator-name = "wl28661d_avdd1";
			regulator-min-microvolt = <1384000>;
			regulator-max-microvolt = <3424000>;
		};

		wl28661d_avdd2: wl28661d-regulator@3 {
			cell-index = <3>;
			reg = /bits/ 8 <0x6>;
			type = "avdd";
			regulator-name = "wl28661d_avdd2";
			regulator-min-microvolt = <1384000>;
			regulator-max-microvolt = <3424000>;
		};
	};
};

&L3F {
	regulator-min-microvolt = <850000>;
	regulator-max-microvolt = <1220000>;
};

&L11B {
	regulator-min-microvolt = <1800000>;
	regulator-max-microvolt = <1800000>;
};

&L13B {
	regulator-min-microvolt = <3300000>;
	regulator-max-microvolt = <3300000>;
};

&L14B {
	regulator-min-microvolt = <2800000>;
	regulator-max-microvolt = <2800000>;
};

 &BOB {
	qcom,hpm-min-load = <10000>;	
	regulator-min-microvolt = <3008000>;
	regulator-max-microvolt = <3960000>;
	qcom,init-voltage = <3328000>;
 };

 &S2B {
	qcom,hpm-min-load = <10000>;	
	regulator-min-microvolt = <1256000>;
	regulator-max-microvolt = <1408000>;
	qcom,init-voltage = <1256000>;
 };

&pmxr2230_flash {
	status = "ok";
};

&pmxr2230_flash0 {
	qcom,max-current-ma = <400>;
	qcom,duration-ms = <300>;
	xiaomi,max-duration-ms = <300>;
	qcom,ires-ua = <5000>;
};

&pmxr2230_flash3 {
        qcom,max-current-ma = <400>;
        qcom,duration-ms = <300>;
        xiaomi,max-duration-ms = <300>;
        qcom,ires-ua = <5000>;
};
&pmxr2230_torch0{
	qcom,max-current-ma = <400>;
	xiaomi,currents-with-time = <400 300>;
	xiaomi,time-for-currents = <5000 0xFFFFFFFF>;  /* 0xFFFFFFFF means flash always on*/
	qcom,ires-ua = <5000>;
};
&pmxr2230_torch3{
        qcom,max-current-ma = <400>;
        xiaomi,currents-with-time = <400 300>;
        xiaomi,time-for-currents = <5000 0xFFFFFFFF>;  /* 0xFFFFFFFF means flash always on*/
        qcom,ires-ua = <5000>;
};
&pmxr2230_switch0 {
	qcom,led-mask = <9>; // Channels 1 & 4
	qcom,symmetry-en;
};


&tlmm {
	flourite_cci_i2c_sda0_active: flourite_cci_i2c_sda0_active {
		mux {
			/* CLK, DATA */
			pins = "gpio88";
			function = "cci_i2c_sda0";
		};

		config {
			pins = "gpio88";
			bias-disable; /* No PULL */
			drive-strength = <2>; /* 2 MA */
		};
	};

	flourite_cci_i2c_scl0_active: flourite_cci_i2c_scl0_active {
		mux {
			/* CLK, DATA */
			pins = "gpio89";
			function = "cci_i2c_scl0";
		};

		config {
			pins = "gpio89";
			bias-disable; /* No PULL */
			drive-strength = <2>; /* 2 MA */
		};
	};

